# Port du serveur (ex: 5001)
PORT=5001

# URL de connexion MongoDB
MONGODB_URI=mongodb+srv://votre_utilisateur:votre_password@cluster.mongodb.net/nom_de_la_bd

# Secret pour les tokens JWT (générer avec : openssl rand -hex 64)
JWT_SECRET=votre_secret_super_secure_min_32_chars

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3001,https://afrikpay-developper.vercel.app

# URL publique du frontend (utilisée pour construire les liens de paiement)
FRONTEND_URL=https://votre-domaine.vercel.app

# Token secret pour sécuriser le webhook Afribapay
# Générer avec : openssl rand -hex 32
# Puis enregistrer l'URL chez Afribapay avec ce token :
#   https://votre-api.com/api/webhooks/afribapay?token=VALEUR_ICI
AFRIBAPAY_WEBHOOK_SECRET=generer_avec_openssl_rand_hex_32
